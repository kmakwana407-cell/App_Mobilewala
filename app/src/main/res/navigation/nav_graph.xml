<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Authentication -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.mobiewala.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_loginFragment_to_adminDashboardFragment"
            app:destination="@id/adminDashboardFragment" />
        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/signupFragment" />
    </fragment>
    <fragment
        android:id="@+id/signupFragment"
        android:name="com.example.mobiewala.auth.SignupFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_signup">
        <action
            android:id="@+id/action_signupFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <!-- User -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.mobiewala.user.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.example.mobiewala.user.ProductDetailFragment"
        android:label="Product Details"
        tools:layout="@layout/fragment_product_detail">
        <argument
            android:name="productId"
            app:argType="long" />
    </fragment>
    <fragment
        android:id="@+id/cartFragment"
        android:name="com.example.mobiewala.user.CartFragment"
        android:label="Cart"
        tools:layout="@layout/fragment_cart" />
    <fragment
        android:id="@+id/ordersFragment"
        android:name="com.example.mobiewala.user.OrdersFragment"
        android:label="My Orders"
        tools:layout="@layout/fragment_orders" />
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.mobiewala.user.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />
    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.example.mobiewala.user.AboutFragment"
        android:label="About"
        tools:layout="@layout/fragment_about" />

    <!-- Admin -->
    <fragment
        android:id="@+id/adminDashboardFragment"
        android:name="com.example.mobiewala.admin.AdminDashboardFragment"
        android:label="Admin Dashboard"
        tools:layout="@layout/fragment_admin_dashboard">
        <action
            android:id="@+id/action_adminDashboardFragment_to_manageProductsFragment"
            app:destination="@id/manageProductsFragment" />
        <action
            android:id="@+id/action_adminDashboardFragment_to_manageUsersFragment"
            app:destination="@id/manageUsersFragment" />
        <action
            android:id="@+id/action_adminDashboardFragment_to_manageOrdersFragment"
            app:destination="@id/manageOrdersFragment" />
    </fragment>

    <fragment
        android:id="@+id/manageProductsFragment"
        android:name="com.example.mobiewala.admin.ManageProductsFragment"
        android:label="Manage Products"
        tools:layout="@layout/fragment_manage_products">
        <action
            android:id="@+id/action_manageProductsFragment_to_addEditProductFragment"
            app:destination="@id/addEditProductFragment" />
    </fragment>

    <fragment
        android:id="@+id/manageUsersFragment"
        android:name="com.example.mobiewala.admin.ManageUsersFragment"
        android:label="Manage Users"
        tools:layout="@layout/fragment_manage_users" />

    <fragment
        android:id="@+id/manageOrdersFragment"
        android:name="com.example.mobiewala.admin.ManageOrdersFragment"
        android:label="Manage Orders"
        tools:layout="@layout/fragment_manage_orders" />

    <fragment
        android:id="@+id/addEditProductFragment"
        android:name="com.example.mobiewala.admin.AddEditProductFragment"
        android:label="Add/Edit Product"
        tools:layout="@layout/fragment_add_edit_product">
        <argument
            android:name="productId"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>

</navigation>